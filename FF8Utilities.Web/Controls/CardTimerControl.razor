@implements IDisposable
@code {
    [Parameter, EditorRequired]
    public CardManipulationModel Model { get; set; }

    [Inject]
    private IJSRuntime JS { get; set; }

    [Inject]
    private NavigationManager NavigationManager { get; set; }


    private InputText _recoveryBoxInput;

    protected override async Task OnInitializedAsync()
    {
        Model.PlayAudio += async (schedule, sound) =>
        {
            string fileName = sound switch
            {
                BeepSound.Ping1 => "ping1.wav",
                BeepSound.Ping2 => "ping2.wav",
                BeepSound.Click => "click1.wav",
                BeepSound.Clack => "clack.wav",
                _ => throw new ArgumentOutOfRangeException()
            };
            await JS.InvokeVoidAsync("audioHelper.playBeep", $"{NavigationManager.BaseUri}res/{fileName}", schedule.Count, schedule.IntervalMs, schedule.InitialDelayMs);
            schedule.OnCompleted?.Invoke();
        };
        Model.PauseAudio += async () =>
        {
            await JS.InvokeVoidAsync("audioHelper.pauseBeeps");
        };

        Model.Redraw += OnRedraw;
        WebHelper.KeyPressed += KeyPressed;
    }

    private async void KeyPressed(object sender, KeyboardEventArgs args)
    {
        if (args.Key == "Enter" || args.Key == "NumpadEnter")
        {
            // Get the current value from the element, as it only writes back on focus lost
            if (_recoveryBoxInput.Element != null)
            {
                var currentValue = await JS.InvokeAsync<string>("eval", $"document.activeElement.value");
                if (currentValue != null) Model.RecoveryPattern = currentValue;
            }

            Model.SubmitCommand.Execute(null);
            if (_recoveryBoxInput.Element != null) await _recoveryBoxInput.Element.Value.FocusAsync();
            OnRedraw();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("JsFunctions.addKeyboardListenerEvent");
        }
    }

    private void OnRedraw()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Model.Redraw -= OnRedraw;
        WebHelper.KeyPressed -= KeyPressed;
    }      
    
    // JSFunctions from https://stackoverflow.com/questions/71242841/listen-to-keyboard-input-in-the-whole-blazor-page
}

<HeadContent>
    <script>
        window.audioHelper = {
            _cancelled: false,
            playBeep: function (url, count, intervalMs, delayMs) {
                this._cancelled = false;
                return new Promise(resolve => {
                    setTimeout(() => {
                        let played = 0;
                        const play = () => {
                            if (this._cancelled) { resolve(); return; }
                            new Audio(url).play();
                            played++;
                            if (played < count) {
                                setTimeout(play, intervalMs);
                            } else {
                                resolve();
                            }
                        };
                        play();
                    }, delayMs);
                });
            },
            pauseBeeps: function () {
                this._cancelled = true;
            }
        };

        window.JsFunctions = {
            addKeyboardListenerEvent: function (foo) {
                let serializeEvent = function (e) {
                    if (e) {
                        return {
                            key: e.key,
                            code: e.keyCode.toString(),
                            location: e.location,
                            repeat: e.repeat,
                            ctrlKey: e.ctrlKey,
                            shiftKey: e.shiftKey,
                            altKey: e.altKey,
                            metaKey: e.metaKey,
                            type: e.type
                        };
                    }
                };

                window.document.addEventListener('keydown', function (e) {
                    DotNet.invokeMethodAsync('FF8Utilities.Web', 'JsKeyDown', serializeEvent(e))
                });
            }
        };
    </script>
</HeadContent>


<div class="container-fluid border border-secondary rounded">
    <div class="row bg-primary d-flex align-items-center py-2">
        <h4 class="fw-bold mb-0">Card Timer</h4>
    </div>
    <div class="row align-items-center">
        <div class="col-md-8 col-12">
            <div class="row align-items-center" style="min-height: 2.5rem;">
                <Spinner Visible="Model.IsTimerRunning" Type="SpinnerType.Dots" Color="SpinnerColor.Primary" Size="SpinnerSize.Large" />
                @if (!Model.IsTimerRunning)
                {
                    <span>@Model.Explanation</span>
                }
            </div>
            <div class="row">
                <InputText @bind-Value="@Model.RecoveryPattern" @ref="_recoveryBoxInput" Placeholder="Enter cards for recovery or 1st try search" />
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.FoundCards))
            {
                <div class="row">
                    <p>@Model.FoundCards</p>
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.ErrorText))
            {
                <div class="row">
                    <p>@Model.ErrorText</p>
                </div>
            }
            <div>
                <p class="card-timer-snake fs-5 fw-bold font-monospace mb-0" style="color: @(Model.TextColor.ToCss())">@(string.IsNullOrEmpty(Model.Snake) ? "\u00A0" : Model.Snake)</p>
            </div>
        </div>
        <div class="col-md-4 col-12">
            <button @onclick="() => Model.SubmitCommand.Execute(null)" class="btn w-100 border border-secondary border-3" style="background-color: @Model.InstantMashBackgroundColor.ToCss())">
                Instant Mash<br />
                @($"{Model.FirstFrameAvailableFramesDisplay} ({Model.InstantMashFramesAvailable} frames)")
            </button>
        </div>
    </div>
</div>