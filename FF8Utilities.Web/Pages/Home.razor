@page "/"
@inherits BasePage
@implements IAsyncDisposable
@code {

    [Inject]
    private NavigationManager NavigationManager { get; set; }

    [Inject]
    private SettingsService SettingsService { get; set; }

    [Inject] 
    private CardTrackerStateService CardTrackerState { get; set; }

    private Modal _cardModal;
    private Modal _cardStrategyModal;
    private Modal _confirmTrackingModal;
    private ZellCardManipulationControl _zellControl;
    private FishFinsControl _fishFinsControl;
    private CarawayCodeControl _carawayCodeControl;

    public override string PageTitle => "FF8 Utilities";

    private async Task CardManipulationClicked(bool isLate)
    {
        await HideModals();

        if (isLate)
        {
            CardTrackerState.SelectedEarlyQuistisPattern = null;
            NavigationManager.NavigateTo("card-tracker");            
        }
        else
        {
            await _cardModal.ShowAsync();
        }
    }

    private async Task HideModals()
    {
        try
        {
            await _cardModal.HideAsync();
        }
        catch
        {
            // Already hidden, or something else, ignore
        }

        try
        {
            await _cardStrategyModal.HideAsync();
        }
        catch
        {
            // Already hidden, or something else, ignore
        }

        try
        {
            await _confirmTrackingModal.HideAsync();
        }
        catch
        {
            // Already hidden, or something else, ignore
        }
    }

    private async Task LaunchCardTracker(uint result)
    {
        await HideModals();
        CardTrackerState.SelectedEarlyQuistisPattern = EarlyQuistisPattern.OptionsExcludeLate.Single(t => t.Result == result);
        await _confirmTrackingModal.ShowAsync();
    }

    public async ValueTask DisposeAsync()
    {
        await HideModals();
    }

    private async Task ProcessEarlyQuistisTrackingStrategy(bool useTracking)
    {
        await HideModals();
        if (useTracking) NavigationManager.NavigateTo($"card-tracker");
        else
        {
            CardTrackerModel model = new CardTrackerModel(SettingsService);            
            _zellControl.Model = (CardManipulationModel)model.CreateCardManipModel(CardTrackerModel.CardManip, CardTrackerState.SelectedEarlyQuistisPattern.Result, "fc01", null);
            await InvokeAsync(async () =>
            {
                await _zellControl.ShowAsync();
            });
        }
    }
}


<ZellCardManipulationControl @ref="_zellControl"/>
<FishFinsControl @ref="_fishFinsControl"/>
<CarawayCodeControl @ref="_carawayCodeControl"/>

<Modal @ref="_cardModal">
    <BodyTemplate>
        <BoardStrategiesControl Strategies="CardViewModelExtensionMethods.EarlyQuistisModels()" FrameSubmitted="LaunchCardTracker" />
    </BodyTemplate>
</Modal>

<Modal @ref="_confirmTrackingModal" Title="Select Tracking Strategy" UseStaticBackdrop="true">
    <BodyTemplate>
        <div class="container text-center">
            <civ class="row">
                <div class="col-6">
                    <Card>
                        <CardTitle>Launch Tracker</CardTitle>
                        <CardBody>Track actions in battle to get zell card first try</CardBody>
                        <Button Block="true" Color="ButtonColor.Primary" Size="ButtonSize.ExtraLarge" @onclick="async () => await ProcessEarlyQuistisTrackingStrategy(true)">Submit</Button>
                    </Card>
                </div>
                <div class="col-6">
                    <Card>
                        <CardTitle>2nd try Zell</CardTitle>
                        <CardBody>Simple approach to get Zell Card on the 2nd game</CardBody>
                        <Button Block="true" Color="ButtonColor.Primary" Size="ButtonSize.ExtraLarge" @onclick="async () => await ProcessEarlyQuistisTrackingStrategy(false)">Submit</Button>
                    </Card>
                </div>
            </civ>
        </div>
    </BodyTemplate>
</Modal>

<Modal @ref="_cardStrategyModal" Title="Select Quistis Strategy">
    <BodyTemplate>
        <div class="container text-center">
            <div class="row">
                <div class="col-6">
                    <Card>
                        <CardTitle>Early</CardTitle>
                        <CardBody>Get Quistis Card before Ifrits Cavern</CardBody>
                        <Button Block="true" Color="ButtonColor.Primary" @onclick="async () => await CardManipulationClicked(false)">Early</Button>
                    </Card>
                </div>
                <div class="col-6">
                    <Card>
                        <CardTitle>Late</CardTitle>
                        <CardBody>Get Quistis Card after returning to Garden</CardBody>
                        <Button Block="true" Color="ButtonColor.Primary" @onclick="async () => await CardManipulationClicked(true)">Late</Button>
                    </Card>
                </div>
            </div>
        </div>        
    </BodyTemplate>
</Modal>


<div class="container text-center">    
    <div class="row">
        <Callout>
            This website is still in beta and many tools are unavailable or untested.
        </Callout>
    </div>
    <div class="row">
        <div class="col-6">
            <Card>
                <CardBody>
                    <CardTitle>Cards</CardTitle>
                    <CardBody>Supports EQ/LQ, First & 2nd try Zell card</CardBody>
                    <Button Block="true" Color="ButtonColor.Primary" Size="ButtonSize.ExtraLarge" @onclick="async () => await _cardStrategyModal.ShowAsync()">Launch</Button>
                </CardBody>
            </Card>
        </div>
        <div class="col-6">
            <Card>
                <CardBody>
                    <CardTitle>Fish Fins</CardTitle>
                    <CardBody>Currently supports Quezacotl fish fin manipulation</CardBody>
                    <Button Block="true" Color="ButtonColor.Primary" Size="ButtonSize.ExtraLarge" @onclick="async () => await _fishFinsControl.ShowAsync()">Launch</Button>
                </CardBody>
            </Card>
        </div>
    </div>
    <div class="row">
        <div class="col-6">
            <Card>
                <CardBody>
                    <CardTitle>Caraway Code</CardTitle>
                    <CardBody>Enter Caraway Mansion early with pole counting</CardBody>
                    <Button Block="true" Color="ButtonColor.Primary" Size="ButtonSize.ExtraLarge" @onclick="async () => await _carawayCodeControl.ShowAsync()">Launch</Button>
                </CardBody>
            </Card>
        </div>
        <div class="col-6">
            <Card>
                <CardBody>
                    <CardTitle>Ultimecia Party</CardTitle>
                    <CardBody>Ensure Irvine is in your starting party for the Ultimecia battle</CardBody>
                    <Button Block="true" Color="ButtonColor.Primary" Size="ButtonSize.ExtraLarge">Launch</Button>
                </CardBody>
            </Card>
        </div>
    </div>    
</div>