@page "/card-info"
@inherits BasePage
@code {

    private List<BaseEncounterModel> Encounters;

    protected override void OnInitialized()
    {
        Encounters = new List<BaseEncounterModel>();
        foreach (Type type in typeof(BaseEncounterModel).Assembly.GetTypes().Where(t => !t.IsAbstract && typeof(BaseEncounterModel).IsAssignableFrom(t)))
        {
            var constructor = type.GetConstructors().First();
            List<object> constructorArgs = new List<object>();
            foreach (var parameter in constructor.GetParameters())
            {
                if (parameter.HasDefaultValue)
                {
                    constructorArgs.Add(parameter.DefaultValue);
                }
                else
                {
                    constructorArgs.Add(Activator.CreateInstance(parameter.ParameterType));
                }
            }

            Encounters.Add((BaseEncounterModel)constructor.Invoke(constructorArgs.ToArray()));

        }

        base.OnInitialized();
    }

    public override string PageTitle => "Card Tracking Information";
}

<div class="container">
<div class="row row-cols-3 g-3">
    @foreach (BaseEncounterModel encounter in Encounters)
    {
        <div class="col">
            <Card TextAlignment="Alignment.Center">
                <CardBody>
                        <CardTitle>@encounter.Description</CardTitle>
                        <span>Base: @encounter.Base</span>
                </CardBody>
                    <Grid TItem="EncounterAbilityModel" Data="@encounter.Abilities" Class="table table-hover table-bordered table-striped">
                        <GridColumn TItem="EncounterAbilityModel" HeaderText="Ability" PropertyName="Description">
                            @context.Description
                        </GridColumn>
                        <GridColumn TItem="EncounterAbilityModel" HeaderText="Addition" PropertyName="Addition" TextAlignment="Alignment.End" HeaderTextAlignment="Alignment.End">
                            @context.Addition
                        </GridColumn>
                    </Grid>
            </Card>
        </div>
    }
    </div>
</div>

