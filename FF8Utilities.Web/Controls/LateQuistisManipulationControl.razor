@code {
    public CardManipulationModel Model { get; set; }

    [Parameter]
    public EventCallback<uint?> OnCompleted { get; set; }

    private Modal _modal;
    private LateQuistisPattern _pattern;
    private LateQuistisStrategy _selectedStrategy;

    private readonly Dictionary<byte[], string> _imageCache = new(ReferenceEqualityComparer.Instance);

    public async Task ShowAsync(LateQuistisPattern pattern)
    {
        _pattern = pattern;
        _selectedStrategy = null;
        _imageCache.Clear();

        // Pre-compute all images
        foreach (var strategy in pattern.Strategies)
        {
            foreach (var card in strategy.OpponentCards)
            {
                if (card == null) return;
                _imageCache.TryAdd(card, BuildDataUrl(card));                
            }

            foreach (var pos in strategy.Positions)
            {
                if (pos.Card == null) return;
                _imageCache.TryAdd(pos.Card, BuildDataUrl(pos.Card));
            }
                
        }

        StateHasChanged();
        await _modal.ShowAsync();
    }

    private async Task ConfirmStrategy()
    {
        if (_selectedStrategy is null) return;
        var result = uint.Parse(_selectedStrategy.ResultHex, System.Globalization.NumberStyles.HexNumber);
        await _modal.HideAsync();
        await OnCompleted.InvokeAsync(result);
    }

    private async Task Cancel()
    {
        await _modal.HideAsync();
        await OnCompleted.InvokeAsync(null);
    }

    private static string BuildDataUrl(byte[] card) => $"data:image/png;base64,{Convert.ToBase64String(card)}";

    private string GetCardImageSource(byte[] card) => _imageCache.TryGetValue(card, out var url) ? url : BuildDataUrl(card);

    private async void SubmitFrame(LateQuistisStrategy frame)
    {
        _selectedStrategy = frame;
        await ConfirmStrategy();
    }
}

<Modal @ref="_modal" Title="Late Quistis" UseStaticBackdrop="true" Fullscreen="ModalFullscreen.Always">
    <BodyTemplate>
        <div class="d-flex flex-column h-100 gap-3 p-2">
            <div style="flex: 2; min-height: 0; overflow: auto;">
                <div class="row h-100">
                    <Tabs NavStyle="NavStyle.Vertical">
                        @foreach (var frame in _pattern.Strategies.OrderBy(t => t.OpponentDeckOrderer))
                        {
                            <Tab>
                                <TitleTemplate>
                                    <div class="row">
                                        @foreach (var image in frame.OpponentCards)
                                        {
                                            <div class="col-md-6">
                                                <Image Src="@GetCardImageSource(image)" IsResponsive="true" />
                                            </div>
                                        }
                                    </div>
                                </TitleTemplate>
                                <Content>
                                    <div class="d-flex flex-column h-100">
                                        <div class="container mb-2">
                                            <div class="border border-secondary rounded">
                                                <div class="row bg-primary d-flex align-items-center py-2">
                                                    <h4 class="fw-bold mb-0">(Frame @frame.Frame) Cards to use</h4>
                                                </div>
                                                <div class="row">
                                                    <span>Funguar, Red Bat, Fastitocalon-F, Caterchipallar, Ifrit</span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="card-grid-center">
                                            <div class="card-grid">
                                                @foreach (var position in frame.Positions)
                                                {
                                                    <div class="card-position">
                                                        <Image Src="@GetCardImageSource(position.Card)" IsResponsive="true" />
                                                        @if (!position.IsPlayerTurn)
                                                        {
                                                            <div class="card-position-disabled-overlay"></div>
                                                        }
                                                        @if (position.ShowTurnNumber)
                                                        {
                                                            <div class="card-position-turn-number @(position.IsPlayerTurn ? "player" : "enemy")">
                                                                @position.Turn
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                        <div class="row d-flex justify-content-center align-items-center mt-2 border border-secondary border-3">
                                            <button class="btn btn-primary btn-lg btn-block" @onclick="() => SubmitFrame(frame)">SUBMIT</button>
                                        </div>
                                    </div>
                                </Content>
                            </Tab>
                        }
                    </Tabs>
                </div>
            </div>
            <div style="flex: 1; min-height: 0;">
                <CardTimerControl Model="@Model" />
            </div>
        </div>
    </BodyTemplate>
</Modal>
