@code {
    [Parameter, EditorRequired]
    public List<CardViewModel> Strategies { get; set; }

    private CardViewModel SelectedModel { get; set; }

    protected override async Task OnInitializedAsync()
    {
        SelectedModel = Strategies?.FirstOrDefault();
    }

    private async Task CardClicked(CardViewModel model)
    {
        SelectedModel = model;
        StateHasChanged();
    }    

    private async Task Submit()
    {
        await FrameSubmitted.InvokeAsync(SelectedModel.RNGResult);
    }

    [Parameter]
    public EventCallback<uint> FrameSubmitted { get; set; }
}

<div class="row">
    <div class="col-4">
        <div class="row overflow-y-auto" style="max-height: 70vh;">
            @foreach (CardViewModel model in Strategies)
            {
                <div class="col-12 mb-2">
                    <button @onclick="async () => await CardClicked(model)"
                            class="card-header p-0 @(model == SelectedModel ? "border border-2 border-white" : string.Empty)">
                        <div class="row g-0">
                            @foreach (var image in model.HeaderCards)
                            {
                                <div class="col-6">
                                    <Image Src="@WebHelper.GetDataImageSource(image)" IsResponsive="true" Style="max-height: 80px; object-fit: contain;" />
                                </div>
                            }
                        </div>
                    </button>
                </div>
            }
        </div>
    </div>
    <div class="col-8">
        <div class="d-flex flex-column h-100 align-items-center">
            <div class="border border-secondary rounded mb-2 text-center">
                <div class="bg-primary d-flex align-items-center py-2 px-2 text-center">
                    <h4>(Frame @SelectedModel.Index) Cards to use</h4>
                </div>
                <div class="px-2 text-center">
                    <span>@SelectedModel.CardsToUse</span>
                </div>
            </div>
            <div class="d-flex flex-column card-grid-responsive-header">
                @if (SelectedModel.Positions == null || SelectedModel.Positions.Length == 0)
                {
                    <span>Frame is not winnable, sorry.  Let us know if you do win!</span>
                }
                else
                {
                    <CardBoardControl Modal="SelectedModel.Positions.ToList()" />
                    <button class="btn btn-primary btn-lg mt-2 border border-secondary border-3" @onclick="Submit">SUBMIT</button>
                }                
            </div>
        </div>
    </div>
</div>
