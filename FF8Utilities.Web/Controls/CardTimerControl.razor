@code {
    [Parameter, EditorRequired]
    public CardManipulationModel Model { get; set; }

    protected override void OnParametersSet()
    {
        Model.Redraw += OnRedraw;
    }

    private void OnRedraw()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Model.Redraw -= OnRedraw;
    }

}


<div class="container-fluid border border-secondary rounded">
    <div class="row bg-primary d-flex align-items-center py-2">
        <h4 class="fw-bold mb-0">Card Timer</h4>
    </div>
    <div class="row align-items-center">
        <div class="col-md-8 col-12">
            <div class="row">
                <p>@Model.Explanation</p>
            </div>
            <div class="row">
                <InputText @bind-Value="@Model.RecoveryPattern" Placeholder="Enter cards for recovery or 1st try search" />
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.FoundCards))
            {
                <div class="row">
                    <p>@Model.FoundCards</p>
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.ErrorText))
            {
                <div class="row">
                    <p>@Model.ErrorText</p>
                </div>
            }
            <div>
                <p class="card-timer-snake fs-5 fw-bold font-monospace mb-0" style="color: @Model.TextColor.ToCss()">@(string.IsNullOrEmpty(Model.Snake) ? "\u00A0" : Model.Snake)</p>
            </div>
        </div>
        <div class="col-md-4 col-12">
            <button @onclick="() => Model.SubmitCommand.Execute(null)" class="btn w-100 border border-secondary border-3" style="background-color: @Model.InstantMashBackgroundColor.ToCss())">
                Instant Mash<br />
                @($"{Model.FirstFrameAvailableFramesDisplay} ({Model.InstantMashFramesAvailable} frames)")
            </button>
        </div>
    </div>
</div>